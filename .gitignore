ML/models/*.pkl
ML/data/raw/*.csv
ML/data/*.csv

# ── Subfolder Cleanup ─────────────────────────────────────
# Ensures we don't accidentally push node_modules if we run npm in root
**/node_modules/
**/__pycache__/
**/dist/
