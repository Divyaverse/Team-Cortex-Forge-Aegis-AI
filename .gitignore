# ── Dependencies ───────────────────────────────────────────
node_modules/
package-lock.json
npm-debug.log
.venv/
env/
venv/
__pycache__/
*.pyc

# ── Environment ──────────────────────────────────────────
.env
.env.local
.env.production

# ── Build/Output ─────────────────────────────────────────
dist/
build/
.next/
*.log

# ── OS & IDE ──────────────────────────────────────────────
.DS_Store
.vscode/
Thumbs.db

# ── Aegis-Specific (Model Artifacts) ───────────────────────
